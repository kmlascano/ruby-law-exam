# Root environment variables
# Copy this file to .env and fill in your values.
# NEVER commit real .env files.

# OpenAI
OPENAI_API_KEY=
OPENAI_MODEL=gpt-5.4-nano
# Optional LLM-as-a-judge quality review
# Set to true to run a second model call that reviews evidence grounding and legal-safety quality.
ENABLE_LLM_JUDGE=true #set to false if you want to disable, just make sure to uncomment AI_PROVIDER
OPENAI_JUDGE_MODEL=gpt-5.4-nano
# AI_PROVIDER=local



# Server
PORT=3001
FRONTEND_URL=http://localhost:5173
